							<Anchors>
								<Anchor point="RIGHT" relativePoint="LEFT">
									<Offset>
										<AbsDimension x="0" y="1"/>
									</Offset>
								</Anchor>
							</Anchors>
						</FontString>
					</Layer>
				</Layers>
				<Scripts>
					<OnLoad>
						if ( Possessions_SearchFullText() == true) then
							self:SetChecked(1);
						else
							self:SetChecked(0);
						end
					</OnLoad>
					<OnClick>
						if( self:GetChecked() == 1) then
							PossessionsData.config.fulltext = true;
							PlaySound("igMainMenuOptionCheckBoxOn");
						else
							PossessionsData.config.fulltext = false;
							PlaySound("igMainMenuOptionCheckBoxOff");
						end
						Possessions_Update();
					 </OnClick>
